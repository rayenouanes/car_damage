# Environnement
APP_ENV=production
PUBLIC_BASE_URL=https://backoffice.example.com

# Securite
# Genere une vraie valeur longue avant de deployer.
AL_API_KEY=change_me_api_key
BACKOFFICE_USERNAME=admin
BACKOFFICE_PASSWORD=change_me_password
AL_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,https://backoffice.example.com

# FastAPI / Streamlit
AL_API_URL=http://api:8000
AL_DATA_DIR=/app/backend/app/data
MAX_VIDEO_FRAMES=500
ACTIVE_LEARNING_THRESHOLD=0.70
YOLO_CONFIDENCE_FLOOR=0.10

# Modeles locaux dans le conteneur
YOLO_MODEL_PATH=/app/models/best_2.pt
SAM2_ENABLED=true
SAM2_PROVIDER=mock
SAM2_CHECKPOINT=/app/models/sam2.1_hiera_tiny.pt
SAM2_MODEL_CONFIG=configs/sam2.1/sam2.1_hiera_t.yaml

# Telechargement modele depuis S3 au demarrage
AWS_REGION=eu-west-3
AWS_S3_BUCKET=your-car-damage-bucket
AWS_S3_PREFIX=car_damage
YOLO_MODEL_S3_URI=s3://your-car-damage-bucket/models/best_2.pt
SAM2_CHECKPOINT_S3_URI=s3://your-car-damage-bucket/models/sam2.1_hiera_tiny.pt

# Options facultatives
USE_CHROMA=false
YOLO_TRAINING_ENABLED=false
